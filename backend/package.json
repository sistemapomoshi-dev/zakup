{
  "name": "@web-app-demo/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run prisma:generate && bun --watch src/index.ts",
    "start": "bun run start:api",
    "start:api": "bun run prisma:generate && bun src/index.ts",
    "start:worker": "bun run prisma:generate && bun src/worker.ts",
    "start:cron": "bun run prisma:generate && bun src/cron.ts",
    "start:raw": "bun src/index.ts",
    "build": "bun run prisma:generate && tsc --noEmit",
    "typecheck": "bun run prisma:generate && tsc --noEmit",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun test src/env.test.ts src/db.test.ts src/contracts.test.ts src/cron.test.ts src/auth/access-tokens.test.ts src/auth/passwords.test.ts src/auth/refresh-tokens.test.ts src/auth/routes.test.ts src/storage/service.test.ts src/mail/attachments/parse.test.ts src/moysklad/match.test.ts src/retail/markup.test.ts src/drafts/workflow.test.ts src/ai/parse-response.test.ts",
    "test:integration": "bun scripts/test-integration.mjs",
    "smoke:docker": "bun scripts/docker-smoke.mjs",
    "prisma": "prisma",
    "prisma:generate": "bun scripts/prisma-generate.mjs",
    "prisma:generate:raw": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@web-app-demo/contracts": "workspace:*",
    "dotenv": "^17.4.2",
    "hono": "^4.12.19",
    "imapflow": "^1.3.7",
    "jose": "^6.2.3",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "~6.0.3"
  }
}
