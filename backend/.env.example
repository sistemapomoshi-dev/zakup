# Local PostgreSQL from ../docker-compose.yml.
# Keep an explicit username and password in Prisma URLs even on local machines.
# Peer-auth style URLs without a user can produce opaque Prisma schema-engine errors.
DATABASE_URL="postgresql://superuser:superpassword@localhost:54329/web_app_demo?schema=public"

# Test PostgreSQL from ../docker-compose.yml. Backend integration, Docker smoke,
# and Playwright E2E use this shape and must target the *_test database.
TEST_DATABASE_URL="postgresql://superuser:superpassword@localhost:54330/web_app_demo_test?schema=public"

JWT_SECRET="replace-with-at-least-32-random-characters"
CORS_ORIGINS="http://localhost:5173,http://localhost:8081,http://localhost:19006"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_DAYS="30"
COOKIE_SECURE="false"

# Optional S3-compatible object storage. Leave blank until the product needs
# uploads, media, or other persistent files. For Yandex Object Storage, use
# SPACES_REGION="ru-central1", SPACES_SIGNING_REGION="ru-central1", and
# SPACES_ENDPOINT="https://storage.yandexcloud.net".
SPACES_REGION=""
SPACES_SIGNING_REGION=""
SPACES_BUCKET=""
SPACES_ENDPOINT=""
SPACES_CDN_BASE_URL=""
SPACES_ACCESS_KEY_ID=""
SPACES_SECRET_ACCESS_KEY=""
SPACES_UPLOAD_MAX_BYTES="10485760"
SPACES_UPLOAD_URL_TTL_SECONDS="900"
SPACES_DOWNLOAD_URL_TTL_SECONDS="300"
SPACES_PUBLIC_CACHE_CONTROL="public, max-age=31536000, immutable"

# Local attachment storage when Spaces is not configured (Phase C).
ATTACHMENT_LOCAL_DIR=""
ATTACHMENT_MAX_BYTES="26214400"

# OCR for image attachments. Install Tesseract OCR locally and override the path
# on Windows if it is not available in PATH.
OCR_TESSERACT_BIN="tesseract"
OCR_TESSERACT_LANG="rus+eng"

# Optional MoySklad integration (Phase D).
MOYSKLAD_API_URL="https://api.moysklad.ru/api/remap/1.2"
MOYSKLAD_LOGIN=""
MOYSKLAD_PASSWORD=""

# Retail marketplace prices (Phase D2).
RETAIL_TARGET_MARGIN_PERCENT="30"
RETAIL_SYNC_ENABLED="true"

# YandexGPT (Phase E). Without keys, dev mock responses are used.
YANDEX_GPT_API_KEY=""
YANDEX_GPT_FOLDER_ID=""
YANDEX_GPT_MODEL="yandexgpt/latest"
YANDEX_GPT_COMPLETION_URL="https://llm.api.cloud.yandex.net/foundationModels/v1/completion"
AI_AUTO_ANALYZE="true"
